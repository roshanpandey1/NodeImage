
<!DOCTYPE html>
<html>
<head>
  <title>File Upload</title>
  <style>
   /* public/css/style.css */

/* Reset & base */
* { box-sizing: border-box; }
html, body { height: 100%; }
body {
  margin: 0;
  font-family: system-ui, -apple-system, Segoe UI, Roboto, Noto Sans, Ubuntu, Cantarell, "Helvetica Neue", Arial, "Apple Color Emoji", "Segoe UI Emoji";
  background: linear-gradient(135deg, #0f172a, #111827);
  color: #e5e7eb;
  display: grid;
  place-items: center;
}

/* Card */
.container {
  width: min(92vw, 720px);
  background: #111827cc; /* translucent card */
  backdrop-filter: blur(6px);
  border: 1px solid #1f2937;
  border-radius: 20px;
  padding: 28px;
  box-shadow: 0 10px 30px rgba(0,0,0,.35);
}

/* Header */
h1 {
  margin: 0 0 16px;
  font-size: clamp(1.4rem, 2.5vw + 0.5rem, 2rem);
  letter-spacing: .3px;
}

/* Subtle divider */
.hr {
  height: 1px;
  background: linear-gradient(90deg, transparent, #374151, transparent);
  margin: 16px 0 24px;
}

/* Form */
form {
  display: grid;
  gap: 14px;
}

label {
  font-size: 0.95rem;
  color: #cbd5e1;
}

/* File input wrapper */
.input-file {
  position: relative;
  display: inline-flex;
  align-items: center;
  gap: 10px;
  border: 1px dashed #334155;
  background: #0b1220;
  padding: 14px 16px;
  border-radius: 14px;
  cursor: pointer;
  transition: border-color .2s ease, background .2s ease;
}
.input-file:hover { border-color: #475569; background: #0d1526; }

.input-file input[type="file"] {
  position: absolute;
  inset: 0;
  opacity: 0;
  cursor: pointer;
}

/* Button */
button[type="submit"] {
  appearance: none;
  border: none;
  background: #2563eb;
  color: white;
  font-weight: 600;
  padding: 12px 18px;
  border-radius: 12px;
  cursor: pointer;
  transition: transform .08s ease, box-shadow .2s ease, background .2s ease;
  box-shadow: 0 6px 18px rgba(37, 99, 235, .35);
}
button[type="submit"]:hover { background: #1d4ed8; }
button[type="submit"]:active { transform: translateY(1px); box-shadow: 0 4px 12px rgba(37, 99, 235, .45); }

/* Uploaded preview */
.preview {
  margin-top: 18px;
  border: 1px solid #1f2937;
  border-radius: 16px;
  overflow: hidden;
  background: #0b1220;
}

.preview img {
  display: block;
  width: 100%;
  height: auto;
  max-height: 420px;
  object-fit: contain;
  background: #0b1220;
}

.preview .meta {
  padding: 12px 14px;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 10px;
  border-top: 1px solid #1f2937;
}
.preview a {
  color: #93c5fd;
  text-decoration: none;
  font-weight: 600;
}
.preview a:hover { text-decoration: underline; }

/* Subtext */
.muted {
  color: #94a3b8;
  font-size: 0.88rem;
}

/* Mobile tweaks */
@media (max-width: 480px) {
  .container { padding: 20px; }
}

  </style>
</head>
<body>
  <h1>Upload File</h1>
  <form action="/upload" method="POST" enctype="multipart/form-data">
    <input type="file" name="file" required />
    <button type="submit">Upload</button>
  </form>

  <% if (url) { %>
    <h2>Uploaded File:</h2>
    <img src="<%= url %>" alt="Uploaded Image" width="300"/>
    <p><a href="<%= url %>" target="_blank">View in Cloudinary</a></p>
  <% } %>
</body>
</html>
